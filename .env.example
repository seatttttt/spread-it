# =====================================================
# Solana
# =====================================================
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_NETWORK=mainnet-beta

# =====================================================
# Helius (https://helius.dev)
# =====================================================
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=
# Shared secret used to validate inbound webhook calls

# =====================================================
# Token (filled after launch on pump.fun)
# =====================================================
TOKEN_MINT=
TOKEN_DECIMALS=6
# Token-2022, 6 decimals

# =====================================================
# Distribution wallet (Patient Zero / dev wallet)
# Generate fresh: solana-keygen new --outfile keypairs/bot.json
# Export private key as base58 to here. NEVER commit.
# =====================================================
DISTRIBUTION_WALLET_PRIVATE_KEY=
DISTRIBUTION_WALLET_PUBLIC_KEY=

# =====================================================
# Supabase (https://supabase.com)
# =====================================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =====================================================
# Spread mechanic config
# =====================================================
TOTAL_SUPPLY=1000000000
# Minimum sender holding to be eligible carrier (% of supply)
CARRIER_MIN_PCT=0.1
# Minimum transfer to count as a spread (% of supply)
SPREAD_MIN_PCT=0.01
# Anti-sybil: recipient must have at least this many SOL
RECIPIENT_MIN_SOL=0.1
# Anti-sybil: recipient must be at least this old (days)
RECIPIENT_MIN_AGE_DAYS=7
# Anti-sybil: recipient must have at least this many outgoing tx
RECIPIENT_MIN_OUTGOING_TX=3
# Drain forfeit threshold (% of peak balance, excl. spread costs)
FORFEIT_DRAIN_PCT=40
# Quarantine duration after forfeit (hours)
QUARANTINE_HOURS=24
# Patient Zero R-floor (ornamental, excluded from distribution)
PATIENT_ZERO_R_FLOOR=10

# =====================================================
# Server
# =====================================================
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
